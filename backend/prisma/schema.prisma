datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("CONSUMER") // "CONSUMER" or "ADMIN"
  createdAt DateTime @default(now())
  tasks     Task[]
}

model Task {
  id            String   @id @default(uuid())
  title         String
  description   String?
  level         String
  status        String
  priority      String
  dueDate       String?
  scheduledDate String?
  parentTaskId  String?
  orderIndex    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
